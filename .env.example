# 数据库连接（密码改成你安装 MySQL 时设的）
DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/yolo_seg?charset=utf8mb4

# Redis（Celery 消息队列）
REDIS_URL=redis://localhost:6379/0

# 文件存储根目录（相对路径，相对于项目根目录）
STORAGE_ROOT=./storage

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=False

# 前端地址（CORS 白名单，多端口兼容）
CORS_ORIGINS=["http://localhost:5174","http://localhost:5173","http://localhost:80","http://localhost"]

# JWT 密钥（请修改为一个复杂字符串）
JWT_SECRET=your_company_secret_key_change_this_to_something_random
